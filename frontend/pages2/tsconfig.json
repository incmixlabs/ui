{
  "compilerOptions": {
    "types": ["@types/wicg-file-system-access", "vite/client"],
    "rootDir": ".",
    "outDir": "./dist",
    "baseUrl": "./src",
     "jsx": "react-jsx",
     "lib": [
      "es2019",
      "dom"
    ],
     "esModuleInterop": true, // E

    "paths": {
      "@/i18n": ["./i18n"],
      "@/i18n/*": ["./i18n/*"],
      "@/pages": ["./index.ts"],
      "@/pages/*": ["./*"],
      "@/auth": ["./auth"],
      "@/auth/*": ["./auth/*"],
      "@/common": ["./common"],
      "@/common/*": ["./common/*"],
      "@/dashboard": ["./dashboard"],
      "@/dashboard/*": ["./dashboard/*"],
      "@/layouts": ["./common/components/layouts"],
      "@/layouts/*": ["./common/components/layouts/*"],
      "@/notes": ["./notes"],
      "@/notes/*": ["./notes/*"],
      "@/orgs": ["./orgs"],
      "@/orgs/*": [".//orgs/*"],
      "@/projects": ["./projects"],
      "@/projects/*": ["./projects/*"],
      "@/roles": ["./roles"],
      "@/roles/*": ["./roles/*"],
      "@/tasks": ["./tasks"],
      "@/tasks/*": ["./tasks/*"],
      "@/translations": ["./translations"],
      "@/translations/*": ["./translations/*"],
      "@/users": ["./users"],
      "@/users/*": ["./users/*"]
    }
  },
  "extends": "@incmix/config/react.json",
  "include": ["."],
  "exclude": ["node_modules"]
}
